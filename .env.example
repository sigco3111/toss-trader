# toss-trader 환경변수 예시 (.env.example)
# 실제 값은 절대 커밋하지 마세요 (.gitignore에서 .env* 추적 금지)
# Vercel 배포 시: vercel.com → Project Settings → Environment Variables에서 추가
# 로컬 dev: 이 파일을 .env.local로 복사 후 본인 값 입력

# ─── 토스 Open API (필수, Runtime) ───────────────────────────
# WTS 로그인 → 설정 > Open API 메뉴에서 client_id/secret 발급
# https://www.tossinvest.com
TOSS_CLIENT_ID=your_client_id_here
TOSS_CLIENT_SECRET=your_client_secret_here

# ─── 토스 Trading Mode (선택, 기본값 paper) ──────────────────
# paper: 주문 endpoint 자동 차단 (HTTP 423)
# live: 실계좌 (Telegram confirm 필수)
# simulation: 시뮬레이션
TOSS_TRADING_MODE=paper

# ─── 토스 안전 가드 (선택, 기본값 있음) ──────────────────────
# 단일 주문 금액 상한 (기본 1,000,000원)
TOSS_MAX_TRADE_AMOUNT=1000000

# 계좌 종류 (pension/ria/综合매매 시 paper 자동 fallback)
# TOSS_ACCOUNT_TYPE_OVERRIDE=

# ─── Telegram (선택, 미설정 시 dev fallback) ────────────────
# BotFather @BotFather → /newbot → 토큰 받기
# 본인 chat_id: @userinfobot 으로 확인
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_CONFIRM_TTL_SEC=300

# ─── 토스 API DRY_RUN (선택, 기본값 true) ──────────────────
# false로 변경 + TOSS_TRADING_MODE=live + Telegram confirm 시 실계좌 주문
DRY_RUN=true
